{
  "name": "@react-native-swc/metro-plugin",
  "version": "0.1.3",
  "description": "SWC plugin ports of Metro's post-transform passes (inline, inline-requires, constant-folding, experimental-imports).",
  "keywords": [
    "bundler",
    "metro",
    "react-native",
    "swc",
    "transformer"
  ],
  "homepage": "https://github.com/oblador/react-native-swc#readme",
  "bugs": {
    "url": "https://github.com/oblador/react-native-swc/issues"
  },
  "license": "MIT",
  "author": "Joel Arvidsson",
  "repository": {
    "type": "git",
    "url": "https://github.com/oblador/react-native-swc.git",
    "directory": "packages/metro-plugin"
  },
  "files": [
    "metro_plugin.wasm",
    "README.md",
    "LICENSE"
  ],
  "main": "./metro_plugin.wasm",
  "exports": {
    ".": "./metro_plugin.wasm",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm build:wasm",
    "build:wasm": "cargo build --target wasm32-wasip1 --release --manifest-path crates/metro_plugin/Cargo.toml && cp ../../target/wasm32-wasip1/release/metro_plugin.wasm ./metro_plugin.wasm",
    "clean": "rm -f metro_plugin.wasm",
    "test": "rstest run",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@rstest/core": "^0.9.9",
    "@swc/core": "^1.15.32",
    "@types/node": "^22.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260426.1"
  },
  "engines": {
    "node": ">=18"
  }
}
